@model FoodieRestaurant.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "Home";
}

<section class="p-5 mb-4 bg-body-tertiary rounded-4 hero">
    <div class="container-fluid py-2">
        <div class="hero-content">
            <h1 class="display-5 fw-bold">Taste the elegant side of food delivery</h1>
            <p class="col-md-10 fs-5">Fresh ingredients, chef-crafted favorites, and lightning-fast ordering.</p>
            <a asp-controller="Menu" asp-action="Index" class="btn btn-warning btn-lg">Order Now</a>
        </div>
    </div>
</section>

<section class="mb-5">
    <h3 class="mb-3">Popular Foods</h3>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
        @foreach (var food in Model.PopularFoods)
        {
            <div class="col mb-4">
                <div class="card h-100 shadow-sm">
                    <img src="@((food.Name?.Contains("Lava Cake", StringComparison.OrdinalIgnoreCase) == true) ? "https://images.unsplash.com/photo-1624353365286-3f8d62daad51?w=800" : 
                (food.Category?.Name == "Pizza") ? "https://images.unsplash.com/photo-1513104890138-7c749659a591?w=800" : 
                (food.Category?.Name == "Burgers") ? "https://images.unsplash.com/photo-1568901346375-23c9450c58cd?w=800" : 
                (food.Category?.Name == "Desserts") ? "https://images.unsplash.com/photo-1551024601-bec78aea704b?w=800" : 
                "https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=800")" 
                         class="card-img-top food-thumb" 
                         alt="@food.Name" 
                         onerror="this.src='https://via.placeholder.com/500x300?text=Food';" />
                    <div class="card-body">
                        <h5>@food.Name</h5>
                        <p class="small text-secondary">@food.Description</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-bold">$@food.Price</span>
                            <a asp-controller="Menu" asp-action="Details" asp-route-id="@food.Id" class="btn btn-outline-warning btn-sm">Details</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</section>

<section class="mb-5">
    <h3 class="mb-3">Categories</h3>
    <div class="d-flex flex-wrap gap-2">
        @foreach (var category in Model.Categories)
        {
            <a asp-controller="Menu" asp-action="Index" asp-route-categoryId="@category.Id" class="btn btn-outline-light">@category.Name</a>
        }
    </div>
</section>

<section class="mb-3">
    <h3>About Us</h3>
    <p>FoodieRestaurant combines premium dine-in taste with modern online convenience. We serve daily from 10:00 AM to 11:00 PM.</p>
</section>
