@model List<FoodieRestaurant.Models.Order>
@{
    ViewData["Title"] = "Manage Orders";
}
<h2>Manage Orders</h2>
<table class="table table-professional">
    <thead><tr><th>#</th><th>User</th><th>Date</th><th>Total</th><th>Status</th><th>Update</th></tr></thead>
    <tbody>
    @foreach (var order in Model)
    {
        <tr>
            <td>@order.OrderId</td>
            <td>@order.User?.Email</td>
            <td>@order.OrderDate.ToLocalTime()</td>
            <td>$@order.TotalPrice</td>
            <td>@order.Status</td>
            <td>
                <form asp-action="UpdateOrderStatus" method="post" class="d-flex gap-2">
                    <input type="hidden" name="orderId" value="@order.OrderId" />
                    <select name="status" class="form-select form-select-sm">
                        @foreach (var s in Enum.GetValues<FoodieRestaurant.Models.OrderStatus>())
                        {
                            <option value="@s" selected="@(order.Status == s)">@s</option>
                        }
                    </select>
                    <button class="btn btn-outline-light btn-sm">Save</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
