@model FoodieRestaurant.ViewModels.PagedFoodListViewModel
@{
    ViewData["Title"] = "Menu";
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
    <h2>Menu</h2>
    <form method="get" class="d-flex gap-2">
        <input name="search" value="@Model.SearchQuery" class="form-control" placeholder="Search foods..." />
        <select name="categoryId" class="form-select">
            <option value="">All Categories</option>
            @foreach (var c in Model.Categories)
            {
                <option value="@c.Id" selected="@(Model.CategoryId == c.Id)">@c.Name</option>
            }
        </select>
        <button class="btn btn-warning">Search</button>
    </form>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
    @foreach (var food in Model.Foods)
    {
        <div class="col mb-4">
            <div class="card h-100">
                <img src="@((food.Name?.Contains("Lava Cake", StringComparison.OrdinalIgnoreCase) == true) ? "https://images.unsplash.com/photo-1624353365286-3f8d62daad51?w=800" : 
            (food.Category?.Name == "Pizza") ? "https://images.unsplash.com/photo-1513104890138-7c749659a591?w=800" : 
            (food.Category?.Name == "Burgers") ? "https://images.unsplash.com/photo-1568901346375-23c9450c58cd?w=800" : 
            (food.Category?.Name == "Desserts") ? "https://images.unsplash.com/photo-1551024601-bec78aea704b?w=800" : 
            "https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=800")" 
                     class="card-img-top food-thumb" 
                     alt="@food.Name" 
                     onerror="this.src='https://via.placeholder.com/500x300?text=Food';" />
                <div class="card-body d-flex flex-column">
                    <h6>@food.Name</h6>
                    <small class="text-secondary mb-2">@food.Category?.Name</small>
                    <p class="small">@food.Description</p>
                    <div class="mt-auto d-flex justify-content-between align-items-center">
                        <strong>$@food.Price</strong>
                        <a asp-action="Details" asp-route-id="@food.Id" class="btn btn-outline-warning btn-sm">Details</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<nav class="mt-4">
    <ul class="pagination">
        @for (var i = 1; i <= Math.Max(1, Model.TotalPages); i++)
        {
            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-search="@Model.SearchQuery" asp-route-categoryId="@Model.CategoryId">@i</a>
            </li>
        }
    </ul>
</nav>
